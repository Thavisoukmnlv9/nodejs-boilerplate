# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                 # development | test | production
PORT=8080
APP_NAME="Business Sync API"
APP_VERSION="0.1.0"
LOG_LEVEL=debug                      # trace|debug|info|warn|error|fatal
ENABLE_DOCS=true                     # expose Swagger UI at /docs (force-off in production unless true)

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
# JWT_SECRET is the HS256 signing key. In a SHARED deployment with the FastAPI
# reference service it MUST equal that service's SECRET_KEY so tokens verify
# across both. Minimum 32 chars (enforced at boot by Zod).
JWT_SECRET=change-me-in-production-min-32-chars-long-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_HOURS=1
# httpOnly refresh cookie (matches the reference service).
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/api/v1/auth
COOKIE_DOMAIN=                       # blank = host-only cookie

# ─── CORS ─────────────────────────────────────────────────────────────────────
# JSON array OR comma-separated list. NEVER "*" in production (credentials:true).
ALLOWED_ORIGINS=["http://localhost:3100","http://localhost:3101","http://localhost:3102","http://localhost:3103","http://localhost:5173"]

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://bsync:bsync_dev@localhost:5432/business_sync?schema=public"

# ─── Redis (cache + rate-limit store + BullMQ) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300                  # entitlements cache TTL (seconds)
BULLMQ_REDIS_URL=redis://localhost:6379/1

# ─── Storage (uploads) ────────────────────────────────────────────────────────
STORAGE_DRIVER=local                 # local | s3
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_MIME=image/png,image/jpeg,image/webp,image/gif,application/pdf
# S3 / S3-compatible (Wasabi, MinIO, R2…) — required when STORAGE_DRIVER=s3
S3_ENDPOINT_URL=https://s3.wasabisys.com
S3_BUCKET=business-sync
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_SIGNED_URL_EXPIRE=3600

# ─── Email (password-reset links; delivery is enqueued to BullMQ) ─────────────
EMAIL_PROVIDER=console               # console | smtp | ses | resend
EMAIL_FROM=noreply@business-sync.io
WEB_BASE_URL=http://localhost:3100   # used to build the reset-password link (no trailing slash)

# ─── Rate limits (per-IP; overridable) ────────────────────────────────────────
RATE_LIMIT_GLOBAL_PER_MINUTE=300
