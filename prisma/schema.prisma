generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Platform Core: Auth & Identity ──────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String?   @unique
  password_hash       String?
  name                String?
  avatar_url          String?
  phone               String?
  status              String    @default("ACTIVE") // ACTIVE | INACTIVE
  email_verified_at   DateTime?
  last_login_at       DateTime?
  mfa_enabled         Boolean   @default(false)
  is_platform_staff   Boolean   @default(false)
  platform_staff_role String? // owner | operator | finance | support (null when not platform staff)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  sessions             Session[]
  organization_members OrganizationMember[]
  files_uploaded       File[]               @relation("FileUploader")
  invitations_sent     OrganizationMember[] @relation("InvitedBy")

  @@map("user")
}

model Session {
  id                 String    @id @default(cuid())
  user_id            String?
  organization_id    String? // current org when session created
  refresh_token_hash String? // hashed refresh token for rotation
  expires_at         DateTime?
  revoked_at         DateTime?
  device_info        String?
  ip_address         String?
  user_agent         String?
  device_fingerprint String?
  is_suspicious      Boolean   @default(false)
  last_active_at     DateTime?
  created_at         DateTime  @default(now())
  deleted_at         DateTime?
  updated_at         DateTime  @default(now()) @updatedAt

  user         User?         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([refresh_token_hash])
  @@index([ip_address])
  @@map("session")
}

// ─── Platform Core: Organizations & Tenancy ──────────────────────────────────

model Organization {
  id            String  @id @default(cuid())
  name          String?
  slug          String? @unique
  logo_url      String?
  brand_color   String?
  timezone      String  @default("Asia/Vientiane")
  locale        String  @default("lo-LA") @db.VarChar(10)
  currency_code String  @default("LAK") @db.VarChar(3)
  tax_rate_bps  Int     @default(0)

  business_legal_name   String?
  tax_id                String?
  billing_email         String?
  support_tier          String?
  deletion_scheduled_at DateTime?
  settings              Json?     @default("{}")
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  sessions              Session[]
  members               OrganizationMember[]
  branches              Branch[]
  roles                 Role[]
  files                 File[]
  entitlement_overrides EntitlementOverride[]

  @@index([deletion_scheduled_at])
  @@map("organization")
}

model OrganizationMember {
  id                    String    @id @default(cuid())
  user_id               String?
  organization_id       String?
  role_id               String?
  is_owner              Boolean   @default(false)
  invited_at            DateTime  @default(now())
  invited_by_id         String?
  invitation_expires_at DateTime?
  invitation_token_hash String?
  accepted_at           DateTime? // null = pending invite
  role_expires_at       DateTime?
  last_active_at        DateTime?
  branch_ids            String[]  @default([])
  default_branch_id     String?
  staff_id              String?
  staff_title           String?
  staff_note            String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt
  deleted_at            DateTime?

  user         User?         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  role         Role?         @relation(fields: [role_id], references: [id], onDelete: Restrict)
  invited_by   User?         @relation("InvitedBy", fields: [invited_by_id], references: [id], onDelete: SetNull)

  @@unique([user_id, organization_id])
  @@index([organization_id])
  @@index([invitation_token_hash])
  @@index([accepted_at])
  @@map("organization_member")
}

// ─── Platform Core: Roles & Permissions ──────────────────────────────────────

model Permission {
  id          String    @id @default(cuid())
  code        String?   @unique // e.g. pos_shop.sell, inventory.adjust
  module      String?
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt
  deleted_at  DateTime?

  role_permissions RolePermission[]

  @@map("permission")
}

model Role {
  // organization_id null = global system role; set = custom role owned by that org.
  id              String    @id @default(cuid())
  organization_id String?
  name            String?
  description     String?
  is_system       Boolean   @default(false)
  parent_role_id  String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  permissions  RolePermission[]
  members      OrganizationMember[]
  organization Organization?        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  parent_role  Role?                @relation("RoleHierarchy", fields: [parent_role_id], references: [id], onDelete: SetNull)
  child_roles  Role[]               @relation("RoleHierarchy")

  @@unique([organization_id, name])
  @@index([organization_id])
  @@map("role")
}

model RolePermission {
  role_id       String
  permission_id String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt
  deleted_at    DateTime?

  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permission")
}

// ─── Platform Core: Branches ─────────────────────────────────────────────────

model Branch {
  id                 String  @id @default(cuid())
  organization_id    String?
  name               String?
  code               String?
  address            String?
  type               String?
  vertical           String?
  settings           Json?   @default("{}")
  is_active          Boolean @default(true)
  is_main            Boolean @default(false)
  phone              String?
  email              String?
  status             String  @default("ACTIVE")
  timezone           String  @default("Asia/Vientiane")
  currency_code      String  @default("LAK") @db.VarChar(3)
  locale             String  @default("lo-LA") @db.VarChar(10)
  tax_rate_bps       Int     @default(0)
  service_fee_bps    Int     @default(0)
  prices_include_tax Boolean @default(true)

  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  deleted_at   DateTime?
  organization Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, code])
  @@index([organization_id])
  @@index([organization_id, vertical])
  @@index([organization_id, is_main])
  @@map("branch")
}

// ─── Platform Core: Subscription & Entitlements ──────────────────────────────

model Plan {
  id                  String    @id @default(cuid())
  name                String?
  slug                String?   @unique
  description         String?
  i18n_key            String?
  billing_interval    String? // MONTHLY | YEARLY
  base_price_cents    Int       @default(0)
  annual_discount_bps Int       @default(2000)
  currency            String    @default("USD")
  is_active           Boolean   @default(true)
  is_public           Boolean   @default(true)
  sort_order          Int       @default(0)
  provider_price_id   String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  plan_features PlanFeature[]

  @@index([is_active, is_public, sort_order])
  @@map("plan")
}

model Feature {
  id          String    @id @default(cuid())
  code        String?   @unique // bulk_export | sso | api_access | ...
  name        String?
  module      String?
  i18n_key    String?
  description String?
  is_metered  Boolean   @default(false)
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  plan_features PlanFeature[]

  @@index([module])
  @@index([is_active])
  @@map("feature")
}

model PlanFeature {
  id           String    @id @default(cuid())
  plan_id      String?
  feature_code String?
  included     Boolean   @default(true)
  limit_value  Int? // null = unlimited
  is_addon     Boolean   @default(false)
  i18n_key     String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  plan    Plan?    @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  feature Feature? @relation(fields: [feature_code], references: [code], onDelete: Restrict)

  @@unique([plan_id, feature_code])
  @@index([plan_id])
  @@index([feature_code])
  @@map("plan_feature")
}

model EntitlementOverride {
  id              String    @id @default(cuid())
  organization_id String?
  kind            String? // feature | module | limit
  code            String? // feature_code | module_code | limit_key
  enabled         Boolean?
  limit_value     Int?
  reason          String?
  granted_by_id   String?
  expires_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  organization Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, kind, code])
  @@index([expires_at])
  @@map("entitlement_override")
}

// ─── Platform Core: Files ────────────────────────────────────────────────────

model File {
  id              String    @id @default(cuid())
  organization_id String?
  bucket          String?
  key             String? // storage key (S3 key or local relative path)
  filename        String?
  content_type    String?
  size_bytes      Int?
  uploaded_by_id  String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt
  deleted_at      DateTime?

  organization Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  uploaded_by  User?         @relation("FileUploader", fields: [uploaded_by_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([bucket, key])
  @@map("file")
}
